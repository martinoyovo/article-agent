# Optional. Only needed for self-hosting or local runs where you do not want to
# paste a key in the UI each time. The public deploy leaves this unset so every
# caller must bring their own key.
ANTHROPIC_API_KEY=

# Optional model overrides.
# DRAFT_MODEL=claude-sonnet-4-6
# FAST_MODEL=claude-haiku-4-5-20251001

# Optional per-IP rate limit (defaults: 5 requests per 60s).
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW_SEC=60
